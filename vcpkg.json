{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "krkr2",
  "version-string": "1.5.0",
  "dependencies": [
    {
      "name": "7zip",
      "platform": "!emscripten"
    },
    {
      "name": "argparse",
      "platform": "linux | windows | osx"
    },
    "boost-iostreams",
    {
      "name": "boost-locale",
      "default-features": false
    },
    {
      "name": "bullet3",
      "platform": "!emscripten"
    },
    "boost-phoenix",
    "boost-spirit",
    {
      "name": "breakpad",
      "default-features": false,
      "platform": "android"
    },
    {
      "name": "catch2",
      "default-features": false,
      "platform": "!android & !ios & !emscripten"
    },
    "cocos2dx",
    {
      "name": "dirent",
      "platform": "windows"
    },
    "ffmpeg",
    "fmt",
    {
      "name": "glfw3",
      "platform": "linux | windows | osx"
    },
    {
      "name": "jxrlib",
      "platform": "!emscripten"
    },
    "libarchive",
    {
      "name": "libgdiplus",
      "platform": "!windows & !emscripten"
    },
    "libjpeg-turbo",
    "libogg",
    {
      "name": "libpng",
      "platform": "!linux & !emscripten"
    },
    "libvorbis",
    "libwebp",
    "lz4",
    "oniguruma",
    {
      "name": "openal-soft",
      "platform": "!emscripten"
    },
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "openmp"
      ],
      "platform": "!emscripten & !osx"
    },
    {
      "name": "opencv4",
      "default-features": false,
      "platform": "emscripten | osx"
    },
    {
      "name": "opus",
      "platform": "android"
    },
    {
      "name": "opusfile",
      "default-features": false
    },
    {
      "name": "sdl2",
      "default-features": false,
      "platform": "!emscripten"
    },
    "spdlog",
    "uchardet",
    "unrar",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    "zstd"
  ],
  "overrides": []
}
